# DevGraph environment config — copy to .env and fill in.

# Optional: GitHub token — STRONGLY recommended.
# Without it GitHub limits you to 60 requests/hr (~15 PRs).
# With it: 5,000 requests/hr.
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here

# Optional: which local Ollama model to use.
# Default is llama3.2 (fast, ~2 GB).
# For better extraction quality use: mistral (5 GB) or llama3.1 (5 GB)
# DEVGRAPH_MODEL=mistral
